# Environment Variables Example

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# Spring Boot
SPRING_APPLICATION_NAME=reward-hub
SPRING_PROFILES_ACTIVE=dev

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_APP=DEBUG

# Database (Currently using in-memory, but available for future enhancement)
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/reward_hub
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=password
# SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Application Features
APP_NAME=RewardHub
APP_VERSION=1.0.0
APP_DESCRIPTION=Cashback Rewards Platform

# Security (for future implementation)
# JWT_SECRET=your-secret-key
# JWT_EXPIRATION=86400000

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=false
